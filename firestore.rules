rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasAuthEmail() {
      return signedIn() && request.auth.token.email != null;
    }

    function authEmail() {
      return string(request.auth.token.email).lower();
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function profileRole() {
      return string(currentProfile().data.role).lower();
    }

    function profileStatus() {
      return string(currentProfile().data.status).lower();
    }

    function hasActiveProfile() {
      return hasProfile()
        && profileStatus() == "active";
    }

    function hasRole(role) {
      return hasActiveProfile()
        && (
          profileRole() == role
          || (role == "paramedic" && profileRole() in ["medic", "ambulance"])
        );
    }

    function isBootstrapAdmin() {
      return hasAuthEmail()
        && authEmail() == "adminsandun@healthlink.lk";
    }

    function hasAdminEmail() {
      return hasAuthEmail()
        && authEmail().matches("^admin.*@healthlink\\.lk$");
    }

    function hasDispatcherEmail() {
      return hasAuthEmail()
        && authEmail().matches("^dispatcher.*@healthlink\\.lk$");
    }

    function hasParamedicEmail() {
      return hasAuthEmail()
        && authEmail().matches("^(paramedic|medic|ambulance|amb).*@healthlink\\.lk$");
    }

    function hasHealthLinkStaffEmail() {
      return hasAuthEmail()
        && authEmail().matches("^(admin|dispatcher|paramedic|medic|ambulance|amb).*@healthlink\\.lk$");
    }

    function canSelfProvisionRole(role) {
      return string(role).lower() == "reporter"
        || (string(role).lower() == "paramedic" && hasParamedicEmail());
    }

    function hasOperationalProfile() {
      return hasActiveProfile()
        && profileRole() in [
          "admin",
          "dispatcher",
          "paramedic",
          "medic",
          "ambulance"
        ];
    }

    function isAdmin() {
      return isBootstrapAdmin()
        || hasAdminEmail()
        || hasRole("admin");
    }

    function isDispatcher() {
      return hasDispatcherEmail()
        || hasRole("dispatcher");
    }

    function isParamedic() {
      return hasParamedicEmail()
        || hasRole("paramedic");
    }

    function canReadOperationalData() {
      return isAdmin()
        || isDispatcher()
        || isParamedic()
        || hasOperationalProfile()
        || hasHealthLinkStaffEmail();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();

      allow list: if isAdmin() || isDispatcher();

      allow create: if isAdmin()
        || (
          isOwner(userId)
          && hasAuthEmail()
          && string(request.resource.data.email).lower() == authEmail()
          && canSelfProvisionRole(request.resource.data.role)
          && string(request.resource.data.status).lower() == "active"
        );

      allow update: if isAdmin()
        || (
          isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            "role",
            "status",
            "createdAt"
          ])
        );

      allow delete: if isAdmin();
    }

    match /Incidents/{incidentId} {
      allow get, list: if canReadOperationalData()
        || (signedIn() && resource.data.reporterId == request.auth.uid)
        || (signedIn() && resource.data.assignedUserId == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid;

      allow update: if isAdmin()
        || isDispatcher()
        || isParamedic()
        || hasOperationalProfile()
        || hasHealthLinkStaffEmail()
        || (signedIn() && resource.data.reporterId == request.auth.uid);

      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
