rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasAuthEmail() {
      return signedIn() && request.auth.token.email != null;
    }

    function hasProfile() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasActiveProfile() {
      return hasProfile()
        && currentProfile().data.status != "Inactive"
        && currentProfile().data.status != "inactive";
    }

    function hasRole(role) {
      return hasActiveProfile()
        && (
          currentProfile().data.role == role
          || (role == "admin" && currentProfile().data.role in ["Admin", "ADMIN"])
          || (role == "dispatcher" && currentProfile().data.role in ["Dispatcher", "DISPATCHER"])
          || (role == "paramedic" && currentProfile().data.role in [
            "Paramedic",
            "PARAMEDIC",
            "medic",
            "Medic",
            "ambulance",
            "Ambulance",
            "AMBULANCE"
          ])
          || (role == "reporter" && currentProfile().data.role in ["Reporter", "REPORTER"])
        );
    }

    function isBootstrapAdmin() {
      return hasAuthEmail() && request.auth.token.email == "adminsandun@healthlink.lk";
    }

    function hasAdminEmail() {
      return hasAuthEmail()
        && request.auth.token.email.matches("^admin.*@healthlink\\.lk$");
    }

    function hasDispatcherEmail() {
      return hasAuthEmail()
        && request.auth.token.email.matches("^dispatcher.*@healthlink\\.lk$");
    }

    function hasParamedicEmail() {
      return hasAuthEmail()
        && request.auth.token.email.matches("^(paramedic|medic|ambulance|amb).*@.*$");
    }

    function hasHealthLinkStaffEmail() {
      return hasAuthEmail()
        && request.auth.token.email.matches("^(admin|dispatcher|paramedic|medic|ambulance).*@healthlink\\.lk$");
    }

    function canSelfProvisionRole(role) {
      return role == "reporter"
        || (role == "paramedic" && hasParamedicEmail());
    }

    function hasOperationalProfile() {
      return hasActiveProfile()
        && currentProfile().data.role in [
          "admin",
          "Admin",
          "ADMIN",
          "dispatcher",
          "Dispatcher",
          "DISPATCHER",
          "paramedic",
          "Paramedic",
          "PARAMEDIC",
          "medic",
          "Medic",
          "ambulance",
          "Ambulance",
          "AMBULANCE"
        ];
    }

    function isAdmin() {
      return isBootstrapAdmin() || hasAdminEmail() || hasRole("admin");
    }

    function isDispatcher() {
      return hasDispatcherEmail() || hasRole("dispatcher");
    }

    function isParamedic() {
      return hasParamedicEmail() || hasRole("paramedic");
    }

    function canReadOperationalData() {
      return isBootstrapAdmin()
        || hasAdminEmail()
        || hasDispatcherEmail()
        || hasParamedicEmail()
        || hasHealthLinkStaffEmail()
        || hasRole("admin")
        || hasRole("dispatcher")
        || hasRole("paramedic")
        || hasOperationalProfile();
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin() || isDispatcher();

      allow create: if isAdmin()
        || (
          isOwner(userId)
          && canSelfProvisionRole(request.resource.data.role)
          && request.resource.data.status == "Active"
        );

      allow update: if isAdmin()
        || (
          isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            "role",
            "status",
            "createdAt"
          ])
        );

      allow delete: if isAdmin();
    }

    match /Incidents/{incidentId} {
      allow get, list: if canReadOperationalData()
        || (signedIn() && resource.data.reporterId == request.auth.uid)
        || (signedIn() && resource.data.assignedUserId == request.auth.uid);

      allow create: if signedIn()
        && request.resource.data.reporterId == request.auth.uid;

      allow update: if isAdmin()
        || isDispatcher()
        || isParamedic()
        || hasOperationalProfile()
        || hasHealthLinkStaffEmail()
        || (signedIn() && resource.data.reporterId == request.auth.uid);

      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
